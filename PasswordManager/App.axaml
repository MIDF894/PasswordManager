<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PasswordManager.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme />

        <Style Selector="ListBoxItem">
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="rgba(255, 255, 255, 0.1)"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontFamily" Value="Onest"/>
            <Setter Property="FontSize" Value="25"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="ExtraLight"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#FF2B2D2C" Offset="0.4" />
                    <GradientStop Color="#802C2B2B" Offset="1.0" />
                </LinearGradientBrush>
            </Setter>
                </Style>

        <Style Selector="Border.Wrapper">
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Onest"/>
        </Style>

        <Style Selector="Button.clearButton">
            <Setter Property="IsVisible" Value="False"/>
        </Style>

        <Style Selector="TextBox:not(:empty) Button.clearButton">
            <Setter Property="IsVisible" Value="True"/>
        </Style>

        <Style Selector="Button:pointerover">
			<Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
            <Setter Property="Foreground" Value="#40FFFFFF" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background">
				<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Offset="0" Color="#FF1F1F1F" />
                    <GradientStop Offset="1" Color="#33132D44" />
                </LinearGradientBrush>
            </Setter>
            <Setter Property="BorderBrush" Value="#3785F1"/>
        </Style>

        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background">
				<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Offset="0" Color="#FF1F1F1F" />
                    <GradientStop Offset="1" Color="#33132D44" />
                </LinearGradientBrush>
            </Setter>
            <Setter Property="BorderBrush" Value="#3785F1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

    </Application.Styles>
</Application>